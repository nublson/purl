# Better Auth (min 32 chars: openssl rand -base64 32)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Supabase PostgreSQL
# Transaction mode for Prisma; Direct for migrations
DATABASE_URL=
# Pooled Supabase connections can time out on Prisma migration advisory locks; set to 1 when needed
# PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1
# Supabase project URL (used by realtime/storage clients)
NEXT_PUBLIC_SUPABASE_URL=
# Optional server-only alias for NEXT_PUBLIC_SUPABASE_URL
# SUPABASE_URL=
# Supabase service role key (server only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=
# Supabase anon key (browser client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=
# Optional: from address (e.g. "App <noreply@yourdomain.com>"); defaults to onboarding@resend.dev
# RESEND_FROM=
# Inbox for in-app feedback (POST /api/feedback); comma-separated for multiple recipients
FEEDBACK_TO_EMAIL=

# Vercel AI Gateway (chat + embeddings — Claude + OpenAI text-embedding-3-small via gateway)
# In-app calls set gateway user + tags (e.g. feature:chat, feature:ingest, feature:semantic-search) for dashboard / spend reports.
# Option A (preferred on Vercel): OIDC — run `vercel env pull` to provision VERCEL_OIDC_TOKEN
# VERCEL_OIDC_TOKEN=
# Option B: static key (CI or non-Vercel); gateway reads AI_GATEWAY_API_KEY when OIDC is unavailable
AI_GATEWAY_API_KEY=

# OpenAI API Key — Whisper transcription only (direct OpenAI; AI Gateway has no transcription API)
OPENAI_API_KEY=

# ElevenLabs (speech-to-text / Scribe realtime dictation)
ELEVENLABS_API_KEY=

# Stripe Billing (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Create a one-time Pro product price ($39) in Stripe Dashboard (test mode first)
STRIPE_PRICE_PRO_ONETIME=
# Optional: POST /api/admin/grants with header x-admin-token
ADMIN_TOKEN=

# Comma-separated origins allowed to call POST /api/links via CORS (e.g. https://nublson.com,https://www.nublson.com)
ALLOWED_ORIGINS=

# Edge rate limiting (src/proxy.ts). Optional locally; set in production to limit /api/auth, chat, links, upload, feedback.
# https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry
SENTRY_AUTH_TOKEN=
# Client + server DSN (optional in local development)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Keep Sentry disabled by default in local dev; set true to test locally
NEXT_PUBLIC_SENTRY_ENABLED=false
SENTRY_ENABLED=false

# Optional: harden server-side URL fetches (safeFetch) — see AGENTS.md
# HTTPS or HTTP CONNECT proxy; proxy host uses pinned DNS/connect. Do not use NO_PROXY to bypass.
# SAFE_OUTBOUND_HTTP_PROXY=http://user:pass@proxy.example.com:3128
# SOCKS5 (Undici experimental); TCP to SOCKS host is not pinned in-app. Set only one of HTTP or SOCKS.
# SAFE_OUTBOUND_SOCKS_PROXY=socks5://127.0.0.1:1080
# Comma-separated DNS resolvers for dns.lookup (e.g. 1.1.1.1,8.8.8.8); not a substitute for DoH or a proxy.
# SAFE_OUTBOUND_DNS_SERVERS=

# Encryption key (32 bytes, 64 hex chars)
ENCRYPTION_KEY=