# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/cypress/screenshots
/cypress/videos
cypress.env.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.cursor/*.log
# Cursor hook ephemeral state (per-machine; do not commit)
.cursor/hooks/state/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Sentry Config File
.env.sentry-build-plugin

.flaskenv*
!.env.project
!.env.vault

# Source maps
*.map

# Browser extension build output
/extension/dist/
/extension/node_modules/

# Serwist (generated at build)
public/sw.js
public/sw.js.map
public/swe-worker-*.js
public/swe-worker-*.js.map
.env*.local
purl-extension.zip
