{
  "manifest_version": 3,
  "name": "Purl",
  "version": "1.0.0",
  "description": "Your personal knowledge base.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Save to Purl"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://purl.nublson.com/*"]
}
